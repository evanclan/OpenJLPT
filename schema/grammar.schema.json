{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openjlpt.dev/schema/grammar.schema.json",
  "title": "OpenJLPT Grammar Entry",
  "description": "A single JLPT grammar point at a given level.",
  "type": "object",
  "required": ["pattern", "level", "meaning"],
  "additionalProperties": false,
  "properties": {
    "pattern": {
      "type": "string",
      "minLength": 1,
      "description": "Grammar pattern (e.g. 〜てもいい)."
    },
    "level": {
      "type": "string",
      "enum": ["N5", "N4", "N3", "N2", "N1"],
      "description": "JLPT level (current N5–N1 system)."
    },
    "meaning": {
      "type": "string",
      "minLength": 1,
      "description": "Concise English meaning or usage."
    },
    "formation": {
      "type": "string",
      "description": "How the pattern is formed (e.g. Verb-te + もいい)."
    },
    "examples": {
      "type": "array",
      "description": "Optional example sentences.",
      "items": {
        "type": "object",
        "required": ["ja", "en"],
        "additionalProperties": false,
        "properties": {
          "ja": { "type": "string", "minLength": 1, "description": "Japanese sentence." },
          "en": { "type": "string", "minLength": 1, "description": "English translation." }
        }
      }
    },
    "tags": {
      "type": "array",
      "description": "Optional topic tags (e.g. permission, conditional, formal).",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": {
      "type": "string",
      "description": "Optional usage notes or caveats."
    }
  }
}
